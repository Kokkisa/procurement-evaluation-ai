# LLM provider — default Anthropic. Swap to openai or ollama by changing LLM_PROVIDER.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# Database — points at a locally-running Postgres (no Docker required).
DATABASE_URL=postgresql+psycopg://proceval:proceval@localhost:5432/proceval

# LLM orchestration rate-limit knobs. Defaults are safe for Anthropic Tier 1.
# Raise LLM_MAX_CONCURRENCY (and lower the sleep) when the org tier is higher.
LLM_MAX_CONCURRENCY=3
LLM_INTER_BATCH_SLEEP_SECONDS=1.5

# Hybrid PDF extraction. OCR fires per-page only when the text layer comes back
# below the threshold (ADR-0006). Requires Tesseract + Poppler binaries on PATH.
OCR_ENABLED=true
OCR_FALLBACK_THRESHOLD=50
OCR_DPI=300

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=procurement-evaluation-ai

# App
UPLOAD_DIR=./data/uploads
OUTPUT_DIR=./data/outputs
LOG_LEVEL=INFO
